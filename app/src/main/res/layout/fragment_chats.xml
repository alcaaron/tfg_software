<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Barra superior -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:title="Chats"
        app:titleTextAppearance="@style/TextAppearance.Material3.HeadlineSmall"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Lista de conversaciones -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Estado vacío -->
    <TextView
        android:id="@+id/emptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aún no hay conversaciones.\nConecta un dispositivo y envía un mensaje."
        android:textAlignment="center"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Speed dial: dim overlay — clickable to close the menu -->
    <View
        android:id="@+id/fabOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#99000000"
        android:alpha="0"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Speed dial: mini-FAB rows, initially invisible (scale=0 set in code) -->
    <LinearLayout
        android:id="@+id/speedDialContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/newMessageFab">

        <!-- Crear grupo -->
        <LinearLayout
            android:id="@+id/speedDialCreateRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="Crear grupo"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/fab_label_background"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/miniFabCreateGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_group_create"
                android:contentDescription="Crear grupo"
                app:backgroundTint="@color/colorPrimary"
                app:tint="@android:color/white"
                app:fabSize="mini"/>

        </LinearLayout>

        <!-- Unirse a grupo -->
        <LinearLayout
            android:id="@+id/speedDialJoinRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="Unirse a grupo"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/fab_label_background"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/miniFabJoinGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_group_join"
                android:contentDescription="Unirse a grupo"
                app:backgroundTint="@color/colorPrimary"
                app:tint="@android:color/white"
                app:fabSize="mini"/>

        </LinearLayout>

        <!-- Mensaje directo -->
        <LinearLayout
            android:id="@+id/speedDialMessageRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="Mensaje directo"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/fab_label_background"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/miniFabNewMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_new_chat"
                android:contentDescription="Mensaje directo"
                app:backgroundTint="@color/colorPrimary"
                app:tint="@android:color/white"
                app:fabSize="mini"/>

        </LinearLayout>

    </LinearLayout>

    <!-- FAB principal (nuevo mensaje / cerrar menú) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/newMessageFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="112dp"
        android:src="@drawable/ic_new_chat"
        android:contentDescription="Nuevo mensaje"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
