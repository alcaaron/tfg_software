<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="960"
    android:viewportHeight="960">
    <!-- Paper airplane pointing upper-right (diagonal NE).
         Even-odd fill creates a visible wing-crease cut-out near the nose. -->
    <path
        android:fillColor="@android:color/white"
        android:fillType="evenOdd"
        android:pathData="M80,880 L880,80 L880,880 Z M880,80 L560,480 L600,600 Z"/>
</vector>
